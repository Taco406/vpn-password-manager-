# SENTINEL sync API service configuration.
# Copy to services/api/.env for local development. NEVER commit a filled-in .env.
# The desktop app and local vault work WITHOUT any of this — the API is only
# needed for multi-device sync, new-device approval, and iPhone-unlock relay.

# Postgres connection (local dev cluster from `just db-up`).
DATABASE_URL=postgres://sentinel:sentinel@127.0.0.1:5433/sentinel

# ES256 private key (PEM) used to sign short-lived access JWTs. Generate with:
#   openssl ecparam -genkey -name prime256v1 -noout -out jwt.pem
SENTINEL_JWT_ES256_PEM=./jwt.pem

# 32-byte base64 key that encrypts account TOTP secrets at rest (server-side).
# The server necessarily holds this — see DECISIONS.md. It does NOT protect the
# vault; vault plaintext is never derivable from anything the server holds.
SENTINEL_TOTP_ENC_KEY=

# Google OAuth client id (public) used to verify id_tokens on /v1/auth/google.
GOOGLE_OAUTH_CLIENT_ID=

# Bind address for the API.
SENTINEL_API_BIND=127.0.0.1:8787

# Set to "production" on a real deployment. In production the server REFUSES to boot
# unless SENTINEL_JWT_ES256_PEM, GOOGLE_OAUTH_CLIENT_ID, and SENTINEL_TOTP_ENC_KEY are
# all set — it will not silently fall back to dev fixtures (mock Google verifier /
# ephemeral JWT key). Leave unset for local dev.
SENTINEL_ENV=

# Only set to 1 if the API runs behind a trusted reverse proxy that sets X-Forwarded-For.
# When unset, rate limiting keys off the real TCP peer IP (not spoofable).
SENTINEL_TRUST_FORWARDED_FOR=

# Comma-separated browser origins allowed by CORS in production (e.g. https://app.example.com).
# The desktop app is a native client and is unaffected by CORS; leave empty unless a browser
# front-end talks to the API.
SENTINEL_CORS_ALLOWED_ORIGINS=

# Opt-in switch for tests that spend real money / touch real cloud + WG kernel.
# Unset by default; nothing in CI or normal `just test` runs live paths.
RUN_LIVE_VPN_TESTS=
