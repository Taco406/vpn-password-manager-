<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push notifications wake the app for unlock approvals. Switch to "production" when you
	     distribute via TestFlight / the App Store. -->
	<key>aps-environment</key>
	<string>development</string>
	<!-- Strictest at-rest protection: the app writes no vault data, only the Enclave key reference. -->
	<key>com.apple.developer.default-data-protection</key>
	<string>NSFileProtectionComplete</string>
</dict>
</plist>
