<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>NorthKey</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Wake the app in the background to handle unlock-approval pushes. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- Export compliance: the app uses standard, exempt encryption only (user-data protection —
	     the standard password-manager classification). Declaring it here means TestFlight builds
	     go "Ready to Test" automatically instead of stopping at a manual compliance dialog. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- App Transport Security: the personal sync server is reached by raw IP with a self-signed
	     certificate that the app PINS itself (exact-DER match in CertPinDelegate — stronger than
	     CA trust). ATS at its defaults rejects a self-signed IP endpoint BEFORE the pinning
	     delegate can accept it, surfacing as NSURLErrorSecureConnectionFailed (-1200) — which is
	     exactly why the phone couldn't sign in while the desktop (no ATS) and Safari (manual
	     bypass) could. Turning ATS off hands trust entirely to our certificate pinning, which is
	     the whole security model here. No plaintext ever rides these connections. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<!-- Why the app asks for the camera and Face ID (App Store requires a reason string). -->
	<key>NSCameraUsageDescription</key>
	<string>Scan the Add-a-device QR from NorthKey on your computer to connect this phone.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Unlock your vault with Face ID.</string>
</dict>
</plist>
