{
  "manifest_version": 3,
  "name": "SENTINEL",
  "version": "0.1.0",
  "description": "Vault autofill and VPN status for the SENTINEL desktop app.",
  "minimum_chrome_version": "116",
  "permissions": ["nativeMessaging", "storage", "activeTab", "clipboardWrite"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SENTINEL"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
