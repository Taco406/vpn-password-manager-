{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NorthKey",
  "version": "0.1.55",
  "identifier": "com.sentinel.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm --filter @sentinel/extension build && node scripts/stage-extension.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "NorthKey",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "public.app-category.utilities",
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "upgradeCode": "0bea6fc4-a743-50f9-b645-a8dbd40cb7d3"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    },
    "resources": {
      "resources/extension": "extension"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Taco406/vpn-password-manager-/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwMEYwRkNBMDQ1QkU3MDIKUldRQzUxc0V5ZzhQY0ZwcVphamFrNGo3U1JKTlNuUnRuTWx5YWI0SVU1L2hzUWRGM1JId1J0VWgK"
    }
  }
}
