<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the notarized macOS build. NorthKey is distributed with a
  Developer ID certificate + notarization (NOT the App Store sandbox), so this is the minimal set
  the embedded WebKit web view needs: WKWebView JITs JavaScript, which requires allowing JIT and
  executable memory, and loading the system WebKit frameworks requires disabling library
  validation. No sandbox entitlements are needed (Developer ID apps are not sandboxed), so network
  access and Keychain work without further keys.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
